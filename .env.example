# Copy this file to `.env` and fill in your own keys. Never commit `.env`.

# ── LLM provider (required) ────────────────────────────────────────────────
# Which model backend to use: anthropic | gemini | openrouter
LLM_PROVIDER=anthropic

# Anthropic (default). Required when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Gemini (optional alternative). Required when LLM_PROVIDER=gemini.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash
# GEMINI_GROUNDING=off        # 'off' disables Google Search grounding (quota-limited keys)

# OpenRouter (optional alternative). Required when LLM_PROVIDER=openrouter.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-opus-4.8
# OPENROUTER_FAST_MODEL=meta-llama/llama-3.3-70b-instruct

# ── ICP tuning ─────────────────────────────────────────────────────────────
MIN_ENGINEERS=300
PRIORITY_THRESHOLD=70
STANDARD_THRESHOLD=40

# ── Contacts (Stage 4) ─────────────────────────────────────────────────────
# Apollo REST key → real decision-makers. Without it, Stage 4 falls back to the LLM.
# apollo.io → Settings → API
APOLLO_API_KEY=

# ── Verify (Stage 3.5) ─────────────────────────────────────────────────────
# VERIFY_ENABLED=off          # skip claim-verification entirely
# VERIFY_READER=off           # skip the reader-proxy fallback for JS/blocked pages

# ── Send / CRM / alerts (optional; dry-run to data/outbox/ when unset) ──────
SLACK_WEBHOOK_URL=
INSTANTLY_API_KEY=
INSTANTLY_CAMPAIGN_ID=
HUBSPOT_TOKEN=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3333
